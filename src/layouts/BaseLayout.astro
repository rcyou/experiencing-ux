---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Experiencing UX — Des Moines UX Community",
	description = "Experiencing UX is a network for user experience professionals in Central Iowa who want to connect, share insights, and grow their careers.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Zalando+Sans:wght@400;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body
		class="bg-[linear-gradient(135deg,var(--color-taupe-50)40%,var(--color-blue-50))] font-sans text-slate-900 antialiased"
	>
		<slot />
	</body>
</html>
