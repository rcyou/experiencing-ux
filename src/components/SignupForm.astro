---
const successMessage = "Your info has been submitted. We'll be in touch soon!";
---

<section
	class="max-w-xl rounded-md bg-white/40 border border-slate-200 backdrop-blur-md p-6"
	aria-labelledby="signup-heading"
>
	<h2 id="signup-heading" class="text-xl md:text-3xl leading-tight font-semibold text-blue-600">
		Stay in the know
	</h2>
	<p class="mt-4 text-base leading-normal text-slate-700">
		Curious about what's happening? Add yourself to our mailing list for updates on upcoming
		events &amp; group announcements.
	</p>

	<form id="signup-form" class="mt-4 flex flex-col gap-4" novalidate>
		<div class="grid grid-cols-2 gap-4">
			<div class="flex flex-col gap-2">
				<label for="first-name" class="input-label">
					First Name
				</label>
				<input
					id="first-name"
					name="firstName"
					type="text"
					autocomplete="given-name"
					required
					placeholder="Your First Name"
					class="input-field"
				/>
			</div>
			<div class="flex flex-col gap-2">
				<label for="last-name" class="input-label">
					Last Name
				</label>
				<input
					id="last-name"
					name="lastName"
					type="text"
					autocomplete="family-name"
					required
					placeholder="Your Last Name"
					class="input-field"
				/>
			</div>
		</div>

		<div class="flex flex-col gap-2">
			<label for="email" class="input-label">
				Email Address
			</label>
			<input
				id="email"
				name="email"
				type="email"
				autocomplete="email"
				required
				placeholder="Email Address"
				class="input-field"
			/>
		</div>

		<div class="flex flex-col gap-2">
			<label for="linkedin" class="input-label">
				LinkedIn URL
			</label>
			<input
				id="linkedin"
				name="linkedin"
				type="url"
				inputmode="url"
				required
				placeholder="Your LinkedIn Profile"
				class="input-field"
			/>
			<p class="input-helper">
				Example: https://linkedin.com/in/your-profile-url
			</p>
		</div>

		<button type="submit" class="btn-primary self-start" id="submit-btn">
			<span id="submit-label">Join Us</span>
			<span
				id="submit-spinner"
				class="ml-2 hidden size-4 animate-spin rounded-full border-2 border-white/30 border-t-white"
				aria-hidden="true"
			></span>
		</button>
	</form>

	<div
		id="form-alert"
		class="form-alert hidden"
		role="status"
		aria-live="polite"
		hidden
	>
		<p id="form-alert-message" class="flex-1 text-base leading-none"></p>
		<button
			type="button"
			id="form-alert-dismiss"
			class="form-alert-dismiss"
			aria-label="Dismiss message"
		>
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5" aria-hidden="true">
				<path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
			</svg>
		</button>
	</div>
</section>

<script define:vars={{ successMessage }}>
	const STORAGE_KEY = "signup-success-message";

	const form = document.getElementById("signup-form");
	const submitBtn = document.getElementById("submit-btn");
	const submitLabel = document.getElementById("submit-label");
	const submitSpinner = document.getElementById("submit-spinner");
	const formAlert = document.getElementById("form-alert");
	const formAlertMessage = document.getElementById("form-alert-message");
	const dismissBtn = document.getElementById("form-alert-dismiss");

	function setLoading(loading) {
		submitBtn.disabled = loading;
		submitBtn.dataset.loading = loading ? "true" : "false";
		submitSpinner.classList.toggle("hidden", !loading);
		submitLabel.textContent = loading ? "Joining…" : "Join Us";
	}

	function showAlert(message, type) {
		formAlertMessage.textContent = message;
		formAlert.classList.remove("hidden", "form-alert--success", "form-alert--error");
		formAlert.classList.add(type === "success" ? "form-alert--success" : "form-alert--error");
		formAlert.hidden = false;

		if (type === "success") {
			sessionStorage.setItem(STORAGE_KEY, message);
		}
	}

	function hideAlert() {
		formAlert.classList.add("hidden");
		formAlert.hidden = true;
		sessionStorage.removeItem(STORAGE_KEY);
	}

	const savedMessage = sessionStorage.getItem(STORAGE_KEY);
	if (savedMessage) {
		showAlert(savedMessage, "success");
	}

	dismissBtn?.addEventListener("click", hideAlert);

	form?.addEventListener("submit", async (event) => {
		event.preventDefault();
		hideAlert();

		if (!form.checkValidity()) {
			form.reportValidity();
			return;
		}

		setLoading(true);

		try {
			const response = await fetch("/api/submit-form", {
				method: "POST",
				body: new FormData(form),
			});

			const data = await response.json();

			if (!response.ok) {
				showAlert(data.error ?? "Something went wrong. Please try again.", "error");
				return;
			}

			form.reset();
			showAlert(data.message ?? successMessage, "success");
		} catch {
			showAlert("Something went wrong. Please try again.", "error");
		} finally {
			setLoading(false);
		}
	});
</script>
